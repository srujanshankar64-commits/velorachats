{
  "$schema": "node_modules/generics/wrangler/config-schema.json",
  "name": "shhchats",
  "compatibility_date": "2025-09-24",
  "compatibility_flags": ["nodejs_compat"],
  "main": "src/server.ts",
  "triggers": {
    "crons": ["* * * * *"]
  },
  "build": {
    "alias": {
      "tanstack-start-manifest:v": ".vite/manifest.json"
    }
  }
}