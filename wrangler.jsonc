{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "shhchats",
  "compatibility_date": "2025-09-24",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "main": "dist/server/index.js",
  "no_bundle": true,
  "assets": {
    "directory": "dist/client"
  },
  "triggers": {
    "crons": [
      "* * * * *"
    ]
  }
}